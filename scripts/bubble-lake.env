# All bubble-specific Lake configuration in ONE place.
#
# TauCeti publishes its own compiled `.olean`s to a public Lake artifact cache on
# Cloudflare R2. Fetching them lets `lake build` recompile only the modules a round
# actually changed, instead of the whole ~600-module library (a cold build is ~40 min).
#
# Lake wants the cache SERVICE (endpoints) as a TOML it reads via $LAKE_CONFIG, and the
# cache TOGGLES as environment variables — so this file materializes the TOML and exports
# the toggles. The worker sources it once per bubble round (see run_in_bubble in
# tauceti_worker/agents.py), so nothing Lake-specific is hardcoded in the worker.
#
# The endpoints are TauCeti CI's public read URLs (pr-build.yml, from the repo variables
# LAKE_CACHE_{ARTIFACT,REVISION}_ENDPOINT_PUBLIC). They are the R2 bucket's public URLs —
# stable across commits. If the maintainer ever rotates the bucket/domain, update the two
# URLs below; this is the ONLY place they live. A miss is safe: the prompts run
# `lake cache get ... || true`, falling back to a full build.

cat > /tmp/tauceti-lake-service.toml <<'TOML'
cache.defaultService = "tauceti-public"
[[cache.service]]
name = "tauceti-public"
kind = "s3"
artifactEndpoint = "https://pub-1825e93d97ca45b2a98d9ad45a5972f8.r2.dev/artifacts"
revisionEndpoint = "https://pub-1825e93d97ca45b2a98d9ad45a5972f8.r2.dev/revisions"
TOML

export LAKE_CONFIG=/tmp/tauceti-lake-service.toml
export LAKE_ARTIFACT_CACHE=true
export LAKE_RESTORE_ARTIFACTS=true
export LAKE_CACHE_DIR=.lake/cache
