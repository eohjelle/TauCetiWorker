# CLI
# ============================================================================

def add_work_flags(p: argparse.ArgumentParser) -> None:
    p.add_argument("--loop", action="store_true", help="keep doing rounds (the driver); default is one round")
    p.add_argument("--only", action="append", default=[], metavar="TASKS",
                   help="restrict to these work units (comma list): " + ", ".join(ALLOWED_TASKS))
    p.add_argument("--agent", choices=AGENTS, default=None,
                   help="which agent to run (default: $TAUCETI_AGENT or auto)")
    # Back-compat aliases for the agent choice.
    g = p.add_mutually_exclusive_group()
    for a in ("codex", "claude", "deepseek", "minimax"):
        g.add_argument(f"--{a}", dest="agent_alias", action="store_const", const=a, help=argparse.SUPPRESS)
    p.add_argument("--host", action="store_true", help="opt OUT of bubble (default: bubble for model modes)")
    p.add_argument("--bubble", action="store_true", help=argparse.SUPPRESS)  # deprecated no-op (now default)
    p.add_argument("--no-pace", dest="no_pace", action="store_true", help="disable the quota pacer")
    p.add_argument("--quota-cmd", default=os.environ.get("TAUCETI_QUOTA_CMD"),
                   help="external command that decides agent availability (overrides the built-in pacer)")
    p.add_argument("--worker-id", dest="worker_id", default=None, help="stable worker id (else 'default')")
    p.add_argument("--isolate-home", dest="isolate_home", action="store_true",
                   help="per-worker Claude/Codex auth state (needed for multi-worker)")
    p.add_argument("--dry-run", dest="dry_run", action="store_true",
                   help="survey + print the picker's decision; act on nothing")


def parse_only(values: list[str]) -> list[str]:
    """Flatten/validate --only (comma lists or repeats). Empty = the full cascade."""
    tasks: list[str] = []
    for v in values:
        for tok in v.replace(" ", "").split(","):
            if not tok:
                continue
            if tok not in ALLOWED_TASKS:
                raise SystemExit(f"unknown --only task '{tok}' (valid: {', '.join(ALLOWED_TASKS)})")  # exit 1; argparse uses 2
            tasks.append(tok)
    return tasks


def resolve_agent(args) -> str:
    if getattr(args, "agent", None) and getattr(args, "agent_alias", None):
        raise SystemExit("pass either --agent or a model alias (--codex/--claude/...), not both")
    return (getattr(args, "agent", None) or getattr(args, "agent_alias", None)
            or os.environ.get("TAUCETI_AGENT") or "auto")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="tauceti", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd")

    w = sub.add_parser("work", help="do work: one round, or the driver loop with --loop")
    add_work_flags(w)

    s = sub.add_parser("status", help="read-only survey of available work + quota")
    s.add_argument("--json", action="store_true", help="emit the survey as JSON")
    s.add_argument("--worker-id", dest="worker_id", default=None)

    sub.add_parser("doctor", help="check the environment (tools, bubble, quota creds)")

    # Hidden internal subcommands.
    r = sub.add_parser("_round", add_help=False)
    add_work_flags(r)
    hb = sub.add_parser("_heartbeat", add_help=False)
    hb.add_argument("key")
    hb.add_argument("--ppipe", type=int, default=None)
    return p


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    cmd = args.cmd

    if cmd is None:
        return cmd_tui(args)
    if cmd == "status":
        return cmd_status(args)
    if cmd in ("work", "_round"):
        only = parse_only(getattr(args, "only", []))
        agent = resolve_agent(args)
        return cmd_work(args, only=only, agent=agent, one_round=(cmd == "_round"))
    if cmd == "doctor":
        return cmd_doctor(args)
    if cmd == "_heartbeat":
        return cmd_heartbeat(args)
    parser.print_help()
    return 64


