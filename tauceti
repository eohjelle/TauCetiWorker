# ReviewState — the PR scoreboard comment is the multi-agent source of truth; a
# short-TTL local cache fronts it. Ports gh_meta/bust_meta/ledger_*/review_* with
# the stale-but-real fallback (never serve a phantom {} over a real cached value).
# Provenance is tracked so mutating passes can refuse to act on stale data.
# ============================================================================

META_RE = re.compile(r"<!--tauceti-meta:v1 (.*?)-->", re.S)
TRUSTED_ASSOC = {"OWNER", "MEMBER", "COLLABORATOR"}


@dataclass
class Meta:
    data: dict
    provenance: str   # "fresh" | "stale" | "missing" | "fetch_failed"


class ReviewState:
    def __init__(self, cfg: Config, gh: GitHub):
        self.cfg = cfg
        self.gh = gh
        self.sbcache = cfg.sbcache

    def _cache_path(self, pr: int) -> Path:
        return self.sbcache / f"{pr}.json"

    def gh_meta(self, pr: int) -> Meta:
        """Newest trusted scoreboard's <!--tauceti-meta:v1 {...}--> JSON, with TTL cache.

        Trust = the <!--tauceti-scoreboard--> marker AND an author with repo association, so a random
        external comment can't forge review state. Empty fetch with a prior cache value → serve the
        stale value (stale-but-real beats a phantom '{}'); only fall to '{}' with no cache at all.
        """
        cache = self._cache_path(pr)
        if cache.exists():
            age = time.time() - cache.stat().st_mtime
            if age < SBCACHE_TTL:
                return Meta(self._load(cache), "fresh")

        comments = self.gh.issue_comments(pr)
        meta_str = ""
        fetch_failed = comments is None
        if comments:
            trusted = [c for c in comments
                       if "<!--tauceti-scoreboard-->" in (c.get("body") or "")
                       and c.get("author_association") in TRUSTED_ASSOC]
            trusted.sort(key=lambda c: c.get("updated_at", ""))
            if trusted:
                body = trusted[-1].get("body") or ""
                matches = META_RE.findall(body)
                if matches:
                    meta_str = matches[-1].strip()

        if not meta_str:
            # Transient fetch failure OR genuinely no scoreboard. If we have a prior value, serve it.
            if cache.exists():
                return Meta(self._load(cache), "stale" if fetch_failed else "fresh")
            return Meta({}, "fetch_failed" if fetch_failed else "missing")

        try:
            data = json.loads(meta_str)
        except json.JSONDecodeError:
            if cache.exists():
                return Meta(self._load(cache), "stale")
            return Meta({}, "missing")
        self.sbcache.mkdir(parents=True, exist_ok=True)
        cache.write_text(json.dumps(data) + "\n")
        return Meta(data, "fresh")

    @staticmethod
    def _load(cache: Path) -> dict:
        try:
            return json.loads(cache.read_text() or "{}")
        except (OSError, json.JSONDecodeError):
            return {}

    def bust(self, pr: int) -> None:
        self._cache_path(pr).unlink(missing_ok=True)

    # --- predicates over the meta (verbatim ports of the round.sh jq) ---
    def ledger_head(self, pr: int) -> str:
        return str(self.gh_meta(pr).data.get("head_sha") or "")

    def ledger_clean_head(self, pr: int) -> str:
        runs = self.gh_meta(pr).data.get("runs") or []
        if runs and all(r.get("verdict") != "error" for r in runs):
            return str(self.gh_meta(pr).data.get("head_sha") or "")
        return ""

    def review_rounds(self, pr: int, counters: Counters) -> int:
        total = self.gh_meta(pr).data.get("round", 0)
        total = total if isinstance(total, int) else 0
        base = counters.read(f"round-base-{pr}")
        return max(0, total - base)

    def ledger_blocking(self, pr: int, head: str) -> bool:
        m = self.gh_meta(pr).data
        if str(m.get("head_sha") or "") != head:
            return False
        runs = m.get("runs") or []
        return any(r.get("verdict") not in ("approve", "error") for r in runs)

    def review_all_green(self, pr: int, head: str) -> Meta:
        """Returns the Meta (so callers can inspect provenance); .data['_all_green'] is the verdict."""
        meta = self.gh_meta(pr)
        m = meta.data
        runs = m.get("runs") or []
        green = (str(m.get("head_sha") or "") == head and len(runs) > 0
                 and all(r.get("verdict") == "approve" for r in runs))
        return Meta({**m, "_all_green": green}, meta.provenance)


# ============================================================================
# Survey — the shared read-only core. Classifies all open PRs per work-kind
# without acting. The picker, `status`, and the TUI all consume this one object.
# ============================================================================

BUILD_FAIL = {"FAILURE", "ERROR", "TIMED_OUT", "CANCELLED", "STARTUP_FAILURE", "ACTION_REQUIRED"}
TARGET_MARKER_RE = re.compile(r"<!--tauceti-target:v1 \{[^}]*\}-->")
TARGET_ID_RE = re.compile(r'"id"\s*:\s*"([^"]+)"')


@dataclass(frozen=True)
class PRInfo:
    number: int
    head_oid: str
    head_ref: str
    head_owner: str
    head_repo: str
    is_draft: bool
    mergeable: str           # MERGEABLE | CONFLICTING | UNKNOWN
    author: str
    build_success: bool
    build_failed: bool

    @staticmethod
    def from_json(d: dict) -> "PRInfo":
        rollup = d.get("statusCheckRollup") or []
        builds = [c for c in rollup if c.get("name") == "build"]
        return PRInfo(
            number=d["number"],
            head_oid=d.get("headRefOid", ""),
            head_ref=d.get("headRefName", ""),
            head_owner=(d.get("headRepositoryOwner") or {}).get("login", ""),
            head_repo=(d.get("headRepository") or {}).get("name", ""),
            is_draft=bool(d.get("isDraft")),
            mergeable=d.get("mergeable", "UNKNOWN"),
            author=(d.get("author") or {}).get("login", ""),
            build_success=any(c.get("conclusion") == "SUCCESS" for c in builds),
            build_failed=any(c.get("conclusion") in BUILD_FAIL for c in builds),
        )


@dataclass
class Candidate:
    pr: int
    head: str
    reason: str = ""
    attempts: int = 0
    budget: int = 0
    provenance: str = "fresh"


@dataclass
class WorkKind:
    name: str
    actionable: list[Candidate] = field(default_factory=list)
    suppressed: list[Candidate] = field(default_factory=list)

    @property
    def count(self) -> int:
        return len(self.actionable)


@dataclass
class BumpStatus:
    master_tip: Optional[str] = None
    our_pin: Optional[str] = None
    behind: bool = False
    bump_pr_open: bool = False
    attempts: int = 0
    due: bool = False


@dataclass
class Survey:
    worker_id: str
    open_prs: list[PRInfo] = field(default_factory=list)
    n_open_nondraft: int = 0
    n_reviewable: int = 0
    rebaseable: WorkKind = field(default_factory=lambda: WorkKind("rebase"))
    reviewable: WorkKind = field(default_factory=lambda: WorkKind("review"))
    needs_fix: WorkKind = field(default_factory=lambda: WorkKind("fix"))
    red_ci: WorkKind = field(default_factory=lambda: WorkKind("fix-ci"))
    bump: BumpStatus = field(default_factory=BumpStatus)
    roadmap_focus: str = ""
    n_mine_open: int = 0
    roadmap_backpressure: bool = False
    mergeable_now: list[Candidate] = field(default_factory=list)
    abandon_eligible: list[Candidate] = field(default_factory=list)
    dup_groups: dict[str, list[int]] = field(default_factory=dict)
    next_auto_stage: Optional[str] = None
    github_failed: bool = False
    errors: list[str] = field(default_factory=list)

    def kind(self, name: str) -> WorkKind:
        return {"rebase": self.rebaseable, "review": self.reviewable,
                "fix": self.needs_fix, "fix-ci": self.red_ci}[name]


def mathlib_master_tip(gh: GitHub) -> Optional[str]:
    return gh.api_jq("repos/leanprover-community/mathlib4/commits/master", ".sha") or None


def our_mathlib_pin(gh: GitHub) -> Optional[str]:
    import base64
    content = gh.api_jq(f"repos/{TAUCETI}/contents/lake-manifest.json?ref=main", ".content")
    if not content:
        return None
    try:
        manifest = json.loads(base64.b64decode(content))
    except Exception:
        return None
    for pkg in manifest.get("packages", []):
        if pkg.get("name") == "mathlib":
            return pkg.get("rev")
    return None


def has_human_activity(gh: GitHub, pr: int) -> bool:
    """Fail-safe: True (treat as human-touched) on any API error or doubt, so we never auto-close a
    PR a person cares about. True if a protective label, or a comment/review by a non-bot non-worker."""
    d = gh.pr_view(pr, ["labels", "comments", "reviews"])
    if d is None:
        return True
    labels = {(l.get("name") or "").lower() for l in (d.get("labels") or [])}
    if labels & {"keep", "hold", "wip", "human", "do-not-close"}:
        return True
    for item in (d.get("comments") or []) + (d.get("reviews") or []):
        login = (item.get("author") or {}).get("login", "")
        if login and login != ME and not login.endswith("[bot]") and not login.startswith("app/"):
            return True
    return False


def survey(cfg: Config, gh: GitHub, rs: ReviewState, counters: Counters,
           *, deep: bool = True) -> Survey:
    """Classify every open PR per work-kind. Read-only — performs no actions.

    `deep=False` skips the per-PR scoreboard reads (faster, coarse) for a quick glance; the picker
    and the housekeeping passes always use deep=True.
    """
    sv = Survey(worker_id=cfg.wid, roadmap_focus=ROADMAP_FOCUS or "any")
    try:
        raw = gh.pr_list(["number", "headRefOid", "headRefName", "headRepositoryOwner",
                          "headRepository", "isDraft", "statusCheckRollup", "author", "mergeable"])
    except GitHubError as e:
        sv.github_failed = True
        sv.errors.append(str(e))
        return sv
    prs = [PRInfo.from_json(d) for d in raw]
    sv.open_prs = prs
    nondraft = [p for p in prs if not p.is_draft]
    mine = [p for p in nondraft if p.author == ME]
    sv.n_open_nondraft = len(nondraft)
    sv.n_reviewable = sum(1 for p in nondraft if p.build_success)
    sv.n_mine_open = len(mine)
    sv.roadmap_backpressure = len(mine) >= MAX_OPEN_PRS

    # 1) rebase: ours, CONFLICTING, under budgets (review budget owns past-budget PRs).
    for p in mine:
        if p.mergeable != "CONFLICTING":
            continue
        c = Candidate(p.number, p.head_oid, "conflicting")
        if deep and rs.review_rounds(p.number, counters) >= MAX_REVIEW_ROUNDS:
            sv.rebaseable.suppressed.append(c); continue
        c.attempts = counters.read(f"rebase-pr-{p.number}"); c.budget = MAX_REBASE_ATTEMPTS
        (sv.rebaseable.suppressed if c.attempts >= c.budget else sv.rebaseable.actionable).append(c)

    # 2) review: non-draft, build-green, current head not cleanly reviewed, under budgets.
    for p in nondraft:
        if not p.build_success:
            continue
        c = Candidate(p.number, p.head_oid, "build-green, head not cleanly reviewed")
        if deep:
            m = rs.gh_meta(p.number); c.provenance = m.provenance
            if rs.ledger_clean_head(p.number) == p.head_oid:
                continue  # already cleanly reviewed at this head
            if rs.review_rounds(p.number, counters) >= MAX_REVIEW_ROUNDS:
                sv.reviewable.suppressed.append(c); continue
            c.attempts = counters.read(f"review-err-{p.number}"); c.budget = MAX_REVIEW_ERRORS
            (sv.reviewable.suppressed if c.attempts >= c.budget else sv.reviewable.actionable).append(c)
        else:
            sv.reviewable.actionable.append(c)

    if deep:
        # 3) fix: ours, reviewed-at-head, latest rubric blocking, under budgets.
        for p in mine:
            if rs.ledger_head(p.number) != p.head_oid:
                continue
            if not rs.ledger_blocking(p.number, p.head_oid):
                continue
            c = Candidate(p.number, p.head_oid, "blocking review at head")
            per_head = counters.read(f"fix-{p.number}-{p.head_oid[:12]}")
            per_pr = counters.read(f"fix-pr-{p.number}")
            c.attempts, c.budget = per_head, MAX_FIX_ATTEMPTS
            if per_head >= MAX_FIX_ATTEMPTS or per_pr >= MAX_FIX_PR_ATTEMPTS:
                sv.needs_fix.suppressed.append(c)
            else:
                sv.needs_fix.actionable.append(c)

    # 4) fix-ci: ours, build FAILED at head, under budgets.
    for p in mine:
        if not p.build_failed:
            continue
        c = Candidate(p.number, p.head_oid, "build failed at head")
        per_head = counters.read(f"ci-{p.number}-{p.head_oid[:12]}")
        per_pr = counters.read(f"ci-pr-{p.number}")
        c.attempts, c.budget = per_head, MAX_CI_ATTEMPTS
        if per_head >= MAX_CI_ATTEMPTS or per_pr >= MAX_CI_PR_ATTEMPTS:
            sv.red_ci.suppressed.append(c)
        else:
            sv.red_ci.actionable.append(c)

    # 4.5) bump: mathlib master ahead of our pin, no bump/hopscotch PR open, under budget.
    bump_open = any(p.head_ref.startswith(BUMP_BRANCH_PREFIX) or p.head_ref.startswith("hopscotch/")
                    for p in nondraft)
    tip = mathlib_master_tip(gh)
    pin = our_mathlib_pin(gh)
    sv.bump = BumpStatus(master_tip=tip, our_pin=pin, bump_pr_open=bump_open)
    if tip and pin:
        sv.bump.behind = tip != pin
        sv.bump.attempts = counters.read(f"bump-{tip[:12]}")
        sv.bump.due = (sv.bump.behind and not bump_open and sv.bump.attempts < MAX_BUMP_ATTEMPTS)

    # Housekeeping classifications (author-scoped; need files/body). These drive merge/abandon/dedup.
    if deep:
        _classify_housekeeping(cfg, gh, rs, counters, sv)

    sv.next_auto_stage = _next_auto_stage(sv)
    return sv


def _classify_housekeeping(cfg, gh, rs, counters, sv: Survey) -> None:
    try:
        mine = gh.pr_list(["number", "headRefOid", "isDraft", "mergeable", "statusCheckRollup",
                           "files", "body"], author=ME)
    except GitHubError as e:
        sv.errors.append(f"housekeeping list: {e}")
        return
    seen: dict[str, int] = {}
    for d in sorted(mine, key=lambda x: x["number"]):
        if d.get("isDraft"):
            continue
        pr, head = d["number"], d.get("headRefOid", "")
        files = [f["path"] for f in (d.get("files") or [])]
        rollup = d.get("statusCheckRollup") or []
        build_green = any(c.get("name") == "build" and c.get("conclusion") == "SUCCESS" for c in rollup)
        green_meta = rs.review_all_green(pr, head)
        all_green = green_meta.data.get("_all_green", False)
        # merge: all rubrics green at head, TauCeti/-only (+ root), MERGEABLE, build green.
        if (all_green and d.get("mergeable") == "MERGEABLE" and build_green
                and files and all(p.startswith("TauCeti/") or p == "TauCeti.lean" for p in files)):
            sv.mergeable_now.append(Candidate(pr, head, "all rubrics green @ head, TauCeti/ only",
                                              provenance=green_meta.provenance))
        # abandon: not green, head IS the reviewed head, past budget, (human-activity checked lazily).
        elif (not all_green and rs.ledger_head(pr) == head
              and rs.review_rounds(pr, counters) >= MAX_REVIEW_ROUNDS):
            if not has_human_activity(gh, pr):
                sv.abandon_eligible.append(Candidate(pr, head, "review budget spent, no human activity",
                                                     attempts=rs.review_rounds(pr, counters),
                                                     budget=MAX_REVIEW_ROUNDS,
                                                     provenance=green_meta.provenance))
        # dedup: newer PR sharing a tauceti-target id with an older open one.
        body = (d.get("body") or "").replace("\n", " ").replace("\r", " ").replace("\t", " ")
        mk = TARGET_MARKER_RE.search(body)
        if mk:
            mid = TARGET_ID_RE.search(mk.group(0))
            if mid:
                tid = mid.group(1)
                if tid in seen:
                    sv.dup_groups.setdefault(tid, [seen[tid]])
                    sv.dup_groups[tid].append(pr)
                else:
                    seen[tid] = pr


def _next_auto_stage(sv: Survey) -> Optional[str]:
    if sv.rebaseable.actionable:
        return "rebase"
    if sv.reviewable.actionable:
        return "review"
    if sv.needs_fix.actionable:
        return "fix"
    if sv.red_ci.actionable:
        return "fix-ci"
    if sv.bump.due:
        return "bump"
    if not sv.roadmap_backpressure:
        return "roadmap"
    return None


# ============================================================================
# Round — the want-gated cascade over survey(). Pre-passes (merge/abandon/dedup)
# always run (quota-free); then ONE work unit. Mirrors round.sh main().
# ============================================================================

def want(only: list[str], task: str) -> bool:
    """Is this work-unit stage enabled? Empty `only` ⇒ everything (do-whatever-is-helpful)."""
    return (not only) or (task in only)


@dataclass
class RoundOpts:
    only: list[str]
    agent: str            # auto|codex|claude|deepseek|minimax (already resolved)
    work_model: str       # the concrete model to run (codex|claude|deepseek|minimax) — set by loop/quota
    sandbox_host: bool    # True = --host (opt out of bubble)
    dry_run: bool
    no_pace: bool = False
    quota_cmd: Optional[str] = None


def _sandbox_for(stage: str, opts: RoundOpts) -> bool:
    """True = bubble. Every model-running stage defaults to bubble; --host opts out."""
    if not SANDBOX_DEFAULT.get(stage, False):
        return False
    return not opts.sandbox_host


def run_round(cfg: Config, gh: GitHub, rs: ReviewState, counters: Counters, opts: RoundOpts) -> int:
    sv = survey(cfg, gh, rs, counters, deep=True)
    if sv.github_failed:
        raise NoProgress("gh pr list failed (GitHub API?) — aborting round, not falling through to authoring")

    # Housekeeping pre-passes — quota-free, run in EVERY mode (land green PRs, retire stuck ones,
    # de-dup). The worker is the only path that merges or retires PRs (CI-side merge is off).
    prepass_merge(cfg, gh, rs, sv, opts.dry_run)
    prepass_dedup(cfg, gh, sv, opts.dry_run)
    prepass_abandon(cfg, gh, rs, sv, opts.dry_run)

    log(f"open PRs: {sv.n_open_nondraft} non-draft, {sv.n_reviewable} build-green")

    # The cascade: first actionable stage wins, does ONE unit, returns its rc.
    for stage in ("rebase", "review", "fix", "fix-ci"):
        if want(opts.only, stage) and sv.kind(stage).actionable:
            c = sv.kind(stage).actionable[0]
            return dispatch(stage, cfg, c, opts)
    if want(opts.only, "bump") and sv.bump.due:
        return dispatch("bump", cfg, Candidate(0, sv.bump.master_tip or "", "bump"), opts)
    if want(opts.only, "roadmap"):
        if sv.roadmap_backpressure:
            raise NoProgress(f"roadmap: {sv.n_mine_open} open PRs (>= {MAX_OPEN_PRS}) — backpressure, not authoring")
        return dispatch("roadmap", cfg, Candidate(0, "", sv.roadmap_focus), opts)

    raise NoProgress(f"no eligible work this round under --only={','.join(opts.only) or '(all)'} "
                     f"(housekeeping pre-passes ran)")


def dispatch(stage: str, cfg: Config, c: Candidate, opts: RoundOpts) -> int:
    sandbox = "bubble" if _sandbox_for(stage, opts) else "host"
    if opts.dry_run:
        target = f"#{c.pr}" if c.pr else (c.head[:12] if c.head else c.reason)
        log(f"[dry-run] would {stage.upper()} {target}  agent={opts.work_model} sandbox={sandbox}")
        return 0
    # Real execution arrives with the agent (M8/M9), review-in-bubble (M9b), and pre-passes (M11).
    raise Die(f"{stage}: real execution not yet wired (milestone 8+); use --dry-run")


# Housekeeping pre-passes (real execution lands in M11; here they dry-run / no-op so the picker runs).
def prepass_merge(cfg, gh, rs, sv: Survey, dry: bool) -> None:
    for c in sv.mergeable_now:
        if c.provenance in ("stale", "fetch_failed"):
            log(f"merge: skip #{c.pr} — scoreboard provenance={c.provenance} (refuse to act on stale data)")
            continue
        log(f"[dry-run] would merge #{c.pr} ({c.reason})" if dry else f"merge: #{c.pr} (M11)")


def prepass_dedup(cfg, gh, sv: Survey, dry: bool) -> None:
    for tid, prs in sv.dup_groups.items():
        for pr in prs[1:]:
            log(f"[dry-run] would close duplicate #{pr} (target '{tid}', keep #{prs[0]})"
                if dry else f"dup-sweep: #{pr} (M11)")


def prepass_abandon(cfg, gh, rs, sv: Survey, dry: bool) -> None:
    for c in sv.abandon_eligible:
        if c.provenance in ("stale", "fetch_failed"):
            log(f"abandon: skip #{c.pr} — provenance={c.provenance}")
            continue
        log(f"[dry-run] would abandon #{c.pr} ({c.reason})" if dry else f"abandon: #{c.pr} (M11)")


