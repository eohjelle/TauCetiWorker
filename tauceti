def _sample(cands: list[Candidate], n: int = 3) -> str:
    nums = [f"#{c.pr}" for c in cands]
    head = " ".join(nums[:n])
    return head + (f" +{len(nums) - n}" if len(nums) > n else "")


def quota_line(snap: dict) -> str:
    """One-line quota summary from a {provider: Provider} snapshot."""
    parts = []
    for name in ("codex", "claude"):
        prov = snap.get(name)
        if prov is None:
            continue
        if prov.error:
            parts.append(f"{name} [yellow]?[/] ({prov.error})")
        elif prov.available:
            parts.append(f"{name} [green]✓[/] {prov.model}")
        else:
            why = prov.model or "over-pace/exhausted"
            parts.append(f"{name} [red]✗[/] ({why})")
    return "   ".join(parts) if parts else "quota: (not checked)"


def render_survey(sv: Survey, console, quota_snap: Optional[dict] = None) -> None:
    from rich.table import Table
    from rich.panel import Panel

    if sv.github_failed:
        console.print(Panel("[bold red]GitHub fetch failed[/] — survey unavailable.\n"
                            + "\n".join(sv.errors), title="tauceti"))
        return

    header = (f"[bold]{TAUCETI}[/]   worker: {sv.worker_id}   "
              f"open: {sv.n_open_nondraft} non-draft, {sv.n_reviewable} build-green")
    if quota_snap is not None:
        header += "\nquota: " + quota_line(quota_snap)
    console.print(Panel(header, title="tauceti"))

    t = Table(show_header=True, header_style="bold")
    t.add_column("KIND"); t.add_column("READY", justify="right"); t.add_column("SAMPLE / NOTE")
    for name in ("rebase", "review", "fix", "fix-ci"):
        wk = sv.kind(name)
        ready = str(wk.count) if wk.count else "—"
        extra = f"  (+{len(wk.suppressed)} past-budget)" if wk.suppressed else ""
        t.add_row(name, ready, (_sample(wk.actionable) or "") + extra)
    # bump
    if sv.bump.due:
        t.add_row("bump", "1", f"mathlib master {sv.bump.master_tip[:12] if sv.bump.master_tip else '?'} ahead of pin")
    else:
        note = "pin current with master" if sv.bump.master_tip and sv.bump.master_tip == sv.bump.our_pin else \
               ("bump PR already open" if sv.bump.bump_pr_open else
                ("over budget" if sv.bump.behind else "unknown"))
        t.add_row("bump", "—", note)
    # roadmap
    if sv.roadmap_backpressure:
        t.add_row("roadmap", "⛔", f"backpressure: {sv.n_mine_open}/{MAX_OPEN_PRS} open  (focus: {sv.roadmap_focus})")
    else:
        t.add_row("roadmap", "∞", f"focus: {sv.roadmap_focus}")
    console.print(t)

    h = Table(show_header=True, header_style="bold dim", title="housekeeping (quota-free, every round)")
    h.add_column("KIND"); h.add_column("READY", justify="right"); h.add_column("SAMPLE / NOTE")
    h.add_row("merge", str(len(sv.mergeable_now)) or "—", _sample(sv.mergeable_now) or "—")
    h.add_row("abandon", str(len(sv.abandon_eligible)) or "—", _sample(sv.abandon_eligible) or "—")
    dups = [pr for group in sv.dup_groups.values() for pr in group[1:]]
    h.add_row("dup-sweep", str(len(dups)) or "—", " ".join(f"#{p}" for p in dups[:3]) or "—")
    console.print(h)

    nxt = sv.next_auto_stage
    console.print(f"\nNext auto round would: [bold]{nxt.upper() if nxt else 'NOTHING (no eligible work)'}[/]")


def cmd_status(args) -> int:
    cfg = Config.resolve(getattr(args, "worker_id", None))
    gh = GitHub()
    rs = ReviewState(cfg, gh)
    counters = Counters(cfg)
    sv = survey(cfg, gh, rs, counters, deep=True)
    _, quota_snap = Quota(cfg).choose(None)

    if getattr(args, "json", False):
        out = {"survey": dataclasses.asdict(sv),
               "quota": {k: dataclasses.asdict(v) for k, v in quota_snap.items()}}
        print(json.dumps(out, indent=2, default=str))
        return 1 if sv.github_failed else 0

    from rich.console import Console
    render_survey(sv, Console(), quota_snap)
    return 1 if sv.github_failed else 0


def cmd_work(args, *, only: list[str], agent: str, one_round: bool) -> int:
    cfg = Config.resolve(getattr(args, "worker_id", None))
    if getattr(args, "loop", False) and not one_round:
        raise SystemExit("tauceti work --loop: the driver loop lands in milestone 12 — one round works now")
    gh = GitHub()
    rs = ReviewState(cfg, gh)
    counters = Counters(cfg)
    # work_model: a forced/aliased agent runs directly; 'auto' is resolved by the pacer in the loop
    # (milestone 12). For a single round, 'auto' shows as 'auto' in dry-run and is resolved at M12.
    work_model = agent if agent != "auto" else "auto"
    opts = RoundOpts(only=only, agent=agent, work_model=work_model,
                     sandbox_host=getattr(args, "host", False), dry_run=getattr(args, "dry_run", False),
                     no_pace=getattr(args, "no_pace", False), quota_cmd=getattr(args, "quota_cmd", None))
    return run_round(cfg, gh, rs, counters, opts)   # NoProgress/Die propagate to main()'s handler


